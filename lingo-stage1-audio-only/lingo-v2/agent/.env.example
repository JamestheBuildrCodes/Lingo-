# ─────────────────────────────────────────────────────────────────────────────
# Lingo Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# LiveKit — same credentials as your backend
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Deepgram — get a NEW key from console.deepgram.com after revoking the old one
DEEPGRAM_API_KEY=your_new_deepgram_key_here
