{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "lingo-api": {
      "source": "lingo-stage1-audio-only/lingo-v2/backend",
      "config": {
        "numReplicas": 1,
        "healthcheckPath": "/health"
      }
    },
    "lingo-agent": {
      "source": "lingo-stage1-audio-only/lingo-v2/agent",
      "config": {
        "numReplicas": 1
      }
    }
  }
}
